---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ '/feed.xml' | url | absoluteUrl(site.url) }}" rel="self"/>
  <link href="{{ '/' | url | absoluteUrl(site.url) }}"/>
  <updated>{{ collections.all | max('date') | isoDate }}</updated>
  <id>{{ '/' | url | absoluteUrl(site.url) }}</id>
  <author>
    <name>{{ site.author.name }}</name>
  </author>
  {%- for post in collections.all | reverse | limit(10) %}
  {%- if not post.data.eleventyExcludeFromCollections %}
  <entry>
    <title>{{ post.data.title or post.fileSlug }}</title>
    <link href="{{ post.url | url | absoluteUrl(site.url) }}"/>
    <updated>{{ post.date | isoDate }}</updated>
    <id>{{ post.url | url | absoluteUrl(site.url) }}</id>
    <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(site.url) }}</content>
  </entry>
  {%- endif %}
  {%- endfor %}
</feed>
