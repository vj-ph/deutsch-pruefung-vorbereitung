<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "OEIF B1 Speaking Exam Prep" }}</title>
  <meta name="description" content="{{ description or 'B1 Speaking Exam Prep – Real Dialogues, Exam-Focused' }}">
  <link rel="icon" href="{{ '/favicon.ico' | url }}">
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
  {% if env == "production" and site.analytics.ga4.enabled and site.analytics.ga4.measurementId %}
  <!-- Google Analytics 4 (Production Only) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.ga4.measurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.ga4.measurementId }}');
  </script>
  {% endif %}
</head>
<body>
  {% include "header.njk" %}
  
  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
</body>
</html>
