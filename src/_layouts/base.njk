{% from "cta-helpers.njk" import samplePagePath with context %}
<!DOCTYPE html>
{% set pageLang = lang or site.language %}
{% set pageDir = dir or 'ltr' %}
<html lang="{{ pageLang }}" dir="{{ pageDir }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="icon" href="{{ '/favicon.ico' | url }}">
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
  {% if site.bookOrder and site.books %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "{{ site.author.name }}",
          "url": "{{ site.author.url }}"
        }{% for bookKey in site.bookOrder %}{% set book = site.books[bookKey] %},
        {
          "@type": "Book",
          "name": "{{ book.title }}",
          {% if book.subtitle %}"alternateName": "{{ book.subtitle }}",{% endif %}
          "description": "{{ book.description }}",
          "inLanguage": "{{ book.language or site.language }}",
          "author": {
            "@type": "Organization",
            "name": "{{ site.author.name }}",
            "url": "{{ site.author.url }}"
          },
          "url": "{{ book.gumroad.fullBook }}",
          "workExample": {
            "@type": "CreativeWork",
            "name": "{{ book.sample.title }}",
            "description": "{{ book.sample.description }}",
            "url": "{{ samplePagePath(book.key, pageLang or 'en') | pageUrl | absoluteUrl(site.url) }}"
          }
        }{% endfor %}
      ]
    }
  </script>
  {% endif %}
  {% if languageLinks %}
    {% for languageLink in languageLinks %}
  <link rel="alternate" hreflang="{{ languageLink.code }}" href="{{ languageLink.url | pageUrl }}">
    {% endfor %}
  {% endif %}
  {% if env == "production" and site.analytics.ga4.enabled and site.analytics.ga4.measurementId %}
  <!-- Google Analytics 4 (Production Only) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.ga4.measurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.ga4.measurementId }}');
  </script>
  {% endif %}
</head>
<body class="{% if pageDir == 'rtl' %}page-rtl{% endif %}">
  {% include "header.njk" %}
  
  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
</body>
</html>
